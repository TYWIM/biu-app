{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.tsx"
  ],
  "project": [
    "src/**",
    "shared/**"
  ],
  "ignore": [
    "dist/**"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": [
    "@tailwindcss/postcss"
  ],
  "ignoreFiles": [
    "dist/**",
    "public/**"
  ],
  "include": [
    "files",
    "dependencies",
    "exports"
  ],
  "includeEntryExports": true,
  "tags": [
    "-lintignore"
  ]
}
